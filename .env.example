# Copy to .env and set values. Used by sweep.sh and train_token_sae.py.
# PROTEIN_DIR or BASE: path to CompleteProteins (protein subdirs with *_pair_block_47.npy)
# GITHUB_TOKEN: for pushing to GitHub (optional; set when pushing from this folder)

# Example (cluster):
# BASE=/storage/scratch1/5/sshrestha304/Autoencoder/CompleteProteins
# GITHUB_TOKEN=ghp_xxxx

# Example (override for sweep.sh):
# PROTEIN_DIR=/path/to/CompleteProteins
